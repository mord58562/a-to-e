          "test": "HbA1c - T1DM target",
          "value": "<= 7.0 %(<= 53 mmol/mol)",
          "units": "% / mmol/mol"
        }
      ]
    },
    "ogtt_pregnancy": {
      "label": "GDM 75g OGTT diagnostic thresholds (ADIPS / RANZCOG)",
      "ranges": [
        {
          "test": "Fasting plasma glucose",
          "value": ">= 5.1 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "1-hour plasma glucose",
          "value": ">= 10.0 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "2-hour plasma glucose",
          "value": ">= 8.5 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "Diagnosis",
          "value": "ONE or more values met or exceeded = GDM",
          "units": "criterion"
        },
        {
          "test": "Timing of screening OGTT",
          "value": "24 - 28 weeks gestation(earlier if high-risk)",
          "units": "criterion"
        },
        {
          "test": "Early OGTT indication",
          "value": "Booking visit - previous GDM, BMI > 30, PCOS, family hx DM, ethnicity, prior macrosomia, glycosuria",
          "units": "criterion"
        },
        {
          "test": "Overt diabetes in pregnancy",
          "value": "Fasting >= 7.0 or random >= 11.1 or HbA1c >= 6.5% - manage as pre-existing DM",
          "units": "criterion"
        }
      ]
    },
    "beta_hcg_pregnancy": {
      "label": "Beta-hCG in early pregnancy",
      "ranges": [
        {
          "test": "Non-pregnant",
          "value": "< 5 IU/L",
          "units": "IU/L"
        },
        {
          "test": "Indeterminate",
          "value": "5 - 25 IU/L(repeat in 48 h)",
          "units": "IU/L"
        },
        {
          "test": "3 weeks (1 week post-conception)",
          "value": "5 - 50 IU/L",
          "units": "IU/L"
        },
        {
          "test": "4 weeks (2 weeks post-conception)",
          "value": "5 - 425 IU/L",
          "units": "IU/L"
        },
        {
          "test": "5 weeks",
          "value": "20 - 7,300 IU/L",
          "units": "IU/L"
        },
        {
          "test": "6 weeks",
          "value": "1,000 - 56,000 IU/L",
          "units": "IU/L"
        },
        {
          "test": "7 - 8 weeks",
          "value": "7,650 - 230,000 IU/L",
          "units": "IU/L"
        },
        {
          "test": "9 - 12 weeks (peak)",
          "value": "25,000 - 290,000 IU/L",
          "units": "IU/L"
        },
        {
          "test": "T2 / T3",
          "value": "Falls to 4,000 - 50,000 IU/L plateau",
          "units": "IU/L"
        },
        {
          "test": "Doubling time (normal early IUP)",
          "value": "48 - 72 h until 6 - 7 weeks; minimum acceptable 53% rise in 48 h",
          "units": "criterion"
        },
        {
          "test": "Discriminatory zone (TVUS)",
          "value": ">= 1,500 - 2,000 IU/L - IUP should be visible; absence raises ectopic suspicion",
          "units": "IU/L"
        },
        {
          "test": "Suboptimal rise (< 53% over 48 h)",
          "value": "Suggests failing IUP or ectopic",
          "units": "criterion"
        },
        {
          "test": "Molar pregnancy",
          "value": "Markedly elevated(often > 100,000) for gestation; snowstorm USS",
          "units": "criterion"
        }
      ]
    },
    "pre_eclampsia_bloods": {
      "label": "Pre-eclampsia - diagnostic criteria & severe features",
      "ranges": [
        {
          "test": "BP threshold",
          "value": ">= 140/90 mmHg on 2 occasions >= 4 h apart, after 20 weeks gestation, in a previously normotensive woman",
          "units": "criterion"
        },
        {
          "test": "Severe BP",
          "value": ">= 160/110 mmHg",
          "units": "criterion"
        },
        {
          "test": "Proteinuria",
          "value": ">= 300 mg / 24 h OR spot protein:creatinine ratio >= 30 mg/mmol OR dipstick >= 2+",
          "units": "criterion"
        },
        {
          "test": "Platelets (end-organ)",
          "value": "< 100 x10^9/L",
          "units": "x10^9/L"
        },
        {
          "test": "Creatinine (end-organ)",
          "value": "> 90 micromol/L OR doubling of baseline",
          "units": "micromol/L"
        },
        {
          "test": "ALT / AST (end-organ)",
          "value": "> 2 x ULN(i.e. > 70 U/L)",
          "units": "U/L"
        },
        {
          "test": "Neurological features",
          "value": "Severe headache, visual disturbance, hyperreflexia, clonus, eclamptic seizure",
          "units": "criterion"
        },
        {
          "test": "Pulmonary oedema",
          "value": "Clinical / imaging - severe feature",
          "units": "criterion"
        },
        {
          "test": "Uteroplacental dysfunction",
          "value": "FGR, oligohydramnios, abnormal umbilical artery Doppler, stillbirth",
          "units": "criterion"
        },
        {
          "test": "HELLP syndrome",
          "value": "Haemolysis(LDH > 600, schistocytes), Elevated Liver enzymes(AST > 70), Low Platelets(< 100)",
          "units": "criterion"
        },
        {
          "test": "Diagnostic combination",
          "value": "Hypertension(after 20 wk) PLUS proteinuria OR any end-organ dysfunction",
          "units": "criterion"
        },
        {
          "test": "Eclampsia",
          "value": "Tonic-clonic seizure in pregnancy/postpartum with pre-eclampsia features",
          "units": "criterion"
        }
      ]
    },
    "lipids": {
      "label": "Lipid profile (adult, fasting)",
      "ranges": [
        {
          "test": "Total cholesterol",
          "value": "< 5.5 mmol/L(desirable)",
          "units": "mmol/L"
        },
        {
          "test": "LDL cholesterol",
          "value": "< 2.0 mmol/L(high CV risk) / < 3.5 mmol/L(general)",
