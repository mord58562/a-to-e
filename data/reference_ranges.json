          "test": "HDL cholesterol (male)",
          "value": "> 1.0 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "Triglycerides",
          "value": "< 2.0 mmol/L(fasting)",
          "units": "mmol/L"
        },
        {
          "test": "Triglycerides",
          "value": "> 10 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "Non-HDL cholesterol",
          "value": "< 2.5 mmol/L(high CV risk)",
          "units": "mmol/L"
        }
      ]
    },
    "calcium_corrected": {
      "label": "Calcium, magnesium, phosphate",
      "ranges": [
        {
          "test": "Total calcium",
          "value": "2.10 - 2.60 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "Ionised calcium",
          "value": "1.15 - 1.30 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "Corrected calcium formula",
          "value": "Corrected Ca = measured Ca + 0.02 x(40 - albumin g/L)",
          "units": "formula"
        },
        {
          "test": "Magnesium",
          "value": "0.7 - 1.1 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "Phosphate (adult)",
          "value": "0.75 - 1.50 mmol/L",
          "units": "mmol/L"
        },
        {
          "test": "Phosphate (child)",
          "value": "1.0 - 2.0 mmol/L(higher than adult; bone growth)",
          "units": "mmol/L"
        },
        {
          "test": "PTH",
          "value": "1.6 - 6.9 pmol/L",
          "units": "pmol/L"
        },
        {
          "test": "25-OH vitamin D",
          "value": "< 30 nmol/L",
          "units": "nmol/L"
        },
        {
          "test": "25-OH vitamin D",
          "value": "30 - 50 nmol/L",
          "units": "nmol/L"
        },
        {
          "test": "25-OH vitamin D",
          "value": ">= 50 nmol/L(end winter); >= 60(other seasons)",
          "units": "nmol/L"
        }
      ]
    },
    "inflammatory_markers": {
      "label": "Inflammatory markers",
      "ranges": [
        {
          "test": "CRP",
          "value": "< 5 mg/L(normal); > 100 mg/L suggests bacterial infection",
          "units": "mg/L"
        },
        {
          "test": "ESR (female)",
          "value": "< 20 mm/h(rises with age and pregnancy)",
          "units": "mm/h"
        },
        {
          "test": "ESR (male)",
          "value": "< 15 mm/h",
          "units": "mm/h"
        },
        {
          "test": "ESR - age-adjusted upper limit (Miller)",
          "value": "Female:(age + 10) / 2; Male: age / 2",
          "units": "formula"
        },
        {
          "test": "Procalcitonin",
          "value": "< 0.5 microg/L(normal); > 2.0 = high probability bacterial sepsis",
          "units": "microg/L"
        },
        {
          "test": "Ferritin (acute phase)",
          "value": "> 500 microg/L in inflammation; > 10,000 raises HLH / Still's",
          "units": "microg/L"
        }
      ]
    },
    "coags": {
      "label": "Coagulation studies",
      "ranges": [
        {
          "test": "INR (off anticoagulation)",
          "value": "0.9 - 1.2",
          "units": "ratio"
        },
        {
          "test": "INR target - AF / DVT-PE on warfarin",
          "value": "2.0 - 3.0",
          "units": "ratio"
        },
        {
